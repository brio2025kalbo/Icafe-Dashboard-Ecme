# ── Nginx reverse-proxy configuration for iCafe Dashboard ────────────────────
#
# 1. Copy this file:
#      sudo cp nginx.conf.example /etc/nginx/sites-available/icafe-dashboard
# 2. Replace every occurrence of YOUR_DOMAIN with your actual domain name.
# 3. Enable the site:
#      sudo ln -s /etc/nginx/sites-available/icafe-dashboard \
#                 /etc/nginx/sites-enabled/icafe-dashboard
# 4. Test and reload:
#      sudo nginx -t && sudo systemctl reload nginx
# 5. (Optional) Issue a free SSL certificate with Certbot:
#      sudo certbot --nginx -d YOUR_DOMAIN
# ─────────────────────────────────────────────────────────────────────────────

# Redirect plain HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN;

    # Let Certbot handle the ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — main server block
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN;

    # ── SSL certificates (filled in automatically by Certbot) ────────────────
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── Security headers ──────────────────────────────────────────────────────
    add_header X-Frame-Options       "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff"      always;
    add_header X-XSS-Protection      "1; mode=block" always;
    add_header Referrer-Policy       "strict-origin-when-cross-origin" always;

    # ── File-upload size limit (adjust to match multer limits in server.cjs) ─
    client_max_body_size 10M;

    # ── Proxy all traffic to the Express/Node server ──────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── Static assets — long-lived cache ─────────────────────────────────────
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        proxy_pass         http://127.0.0.1:3000;
        proxy_set_header   Host $host;
        proxy_cache_bypass $http_upgrade;
        expires            1y;
        # Repeat security headers (add_header is not inherited when redefined in a block)
        add_header Cache-Control          "public, immutable";
        add_header X-Frame-Options        "SAMEORIGIN"   always;
        add_header X-Content-Type-Options "nosniff"      always;
        add_header X-XSS-Protection       "1; mode=block" always;
        add_header Referrer-Policy        "strict-origin-when-cross-origin" always;
    }
}
